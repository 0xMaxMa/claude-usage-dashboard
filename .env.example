# =============================================
# Claude Code Usage Dashboard — Configuration
# =============================================

PORT=3737
SCRAPE_INTERVAL_MIN=5

# ──────────────────────────────────────────
# Single Account (simple setup)
# ──────────────────────────────────────────
# SESSION_KEY=sk-ant-sid02-xxxxxxxxxxxxxxxx
# ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ──────────────────────────────────────────
# Multi-Account (add as many as needed)
# ──────────────────────────────────────────
# ACCOUNT_1_ID=main                         # stable key — set once, never change
# ACCOUNT_1_NAME=Main                       # display name — can be changed anytime
# ACCOUNT_1_SESSION_KEY=sk-ant-sid02-xxxxxxxxxxxxxxxx
# ACCOUNT_1_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ACCOUNT_2_ID=work
# ACCOUNT_2_NAME=Work
# ACCOUNT_2_SESSION_KEY=sk-ant-sid02-xxxxxxxxxxxxxxxx
# ACCOUNT_2_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ACCOUNT_3_ID=personal
# ACCOUNT_3_NAME=Personal
# ACCOUNT_3_SESSION_KEY=sk-ant-sid02-xxxxxxxxxxxxxxxx
# ACCOUNT_3_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ──────────────────────────────────────────
# How to get SESSION_KEY & ORG_ID
# ──────────────────────────────────────────
# SESSION_KEY: Open claude.ai → DevTools → Application → Cookies → copy sessionKey value
# ORG_ID: Run the following command:
#   curl -s "https://api.anthropic.com/api/organizations" \
#     -H "Cookie: sessionKey=<YOUR_SESSION_KEY>" | python3 -m json.tool
#   → copy the "id" field
